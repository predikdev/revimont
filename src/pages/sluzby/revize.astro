---
import { getImage } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import RevizeApproach from "../../components/sections/revize/RevizeApproach.astro";
import ContactSection from "../../components/sections/shared/ContactSection.astro";
import PageHeroServicesNew from "../../components/sections/shared/PageHeroServicesNew.astro";
import RevizeServicesV2 from "../../components/sections/revize/RevizeServicesV2.astro";
import RevizeWhyUs from "../../components/sections/revize/RevizeWhyUs.astro";
import revizeImage from "../../assets/images/revize.jpg";
import { SITE_URL } from "../../data/company";

const titleHtml = `Revizní činnost a kontroly`;
const description =
  "Provádíme pečlivé výchozí i pravidelné revize elektroinstalací a hromosvodů v souladu s platnými normami. Odhalíme skrytá rizika a dodáme vám právně platný revizní protokol.";

const [img640, img1024, img1280] = await Promise.all([
  getImage({ src: revizeImage, width: 640, format: "avif", quality: 75 }),
  getImage({ src: revizeImage, width: 1024, format: "avif", quality: 75 }),
  getImage({ src: revizeImage, width: 1280, format: "avif", quality: 75 }),
]);
const preloadSrcset = `${img640.src} 640w, ${img1024.src} 1024w, ${img1280.src} 1280w`;

const siteUrl = (Astro.site ?? new URL(SITE_URL)).toString().replace(/\/$/, "");
const pageUrl = `${siteUrl}/sluzby/revize`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: "Revize elektroinstalací",
    name: "Revize elektroinstalací a hromosvodů",
    description,
    provider: { "@id": `${siteUrl}/#company` },
    areaServed: { "@type": "AdministrativeArea", name: "Klatovy a okolí" },
    url: pageUrl,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Domů", item: `${siteUrl}/` },
      {
        "@type": "ListItem",
        position: 2,
        name: "Revize elektroinstalací",
        item: pageUrl,
      },
    ],
  },
];
---

<BaseLayout
  pageTitle="Revize elektroinstalací a hromosvodů"
  pageDescription={description}
  ogImage={revizeImage.src}
  ogImageAlt="Revize elektroinstalace a rozvaděče"
  structuredData={structuredData}
>
  <link
    slot="head"
    rel="preload"
    as="image"
    imagesrcset={preloadSrcset}
    imagesizes="100vw"
    fetchpriority="high"
  />
  <PageHeroServicesNew
    id="hero"
    slot="hero"
    eyebrow="Revize Klatovy a okolí"
    titleHtml={titleHtml}
    description={description}
    backgroundImage={revizeImage}
    backgroundImageAlt="Revize elektroinstalace — technický rozvaděč a elektrické rozvody bez osob"
  />

  <RevizeServicesV2 />
  <RevizeApproach />
  <RevizeWhyUs />
  <ContactSection />
</BaseLayout>
