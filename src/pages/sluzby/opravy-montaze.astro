---
import { getImage } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeroServicesNew from "../../components/sections/shared/PageHeroServicesNew.astro";

import OpravyMontazeServices from "../../components/sections/opravy-montaze/OpravyMontazeServices.astro";
import OpravyMontazeWhyUs from "../../components/sections/opravy-montaze/OpravyMontazeWhyUs.astro";
import OpravyMontazeApproach from "../../components/sections/opravy-montaze/OpravyMontazeApproach.astro";
import ContactSection from "../../components/sections/shared/ContactSection.astro";
import rekonstrukceImage from "../../assets/images/rekonstrukce.jpg";

const title = "Montáže a opravy domácích systémů";
const description =
  "Nabízíme odborné opravy a montáže domácích telefonů, zvonkových tabel i elektrických zařízení. Rychle a spolehlivě vyřešíme každou závadu v Klatovech i širokém okolí.";

const [img640, img1024, img1280] = await Promise.all([
  getImage({ src: rekonstrukceImage, width: 640, format: "avif", quality: 75 }),
  getImage({
    src: rekonstrukceImage,
    width: 1024,
    format: "avif",
    quality: 75,
  }),
  getImage({
    src: rekonstrukceImage,
    width: 1280,
    format: "avif",
    quality: 75,
  }),
]);
const preloadSrcset = `${img640.src} 640w, ${img1024.src} 1024w, ${img1280.src} 1280w`;
---

<BaseLayout
  pageTitle="Opravy a montáže"
  pageDescription={description}
  ogImage={rekonstrukceImage.src}
  ogImageAlt="Opravy a montáže domácích systémů"
>
  <link
    slot="head"
    rel="preload"
    as="image"
    imagesrcset={preloadSrcset}
    imagesizes="100vw"
    fetchpriority="high"
  />
  <PageHeroServicesNew
    slot="hero"
    id="hero"
    eyebrow="Opravy a montáže Klatovy a okolí"
    titleHtml={title}
    description={description}
    backgroundImage={rekonstrukceImage}
    backgroundImageAlt="Montáže a opravy — detail zásahu do elektronického zařízení"
  />
  <OpravyMontazeServices />
  <OpravyMontazeApproach />
  <OpravyMontazeWhyUs />
  <ContactSection />
</BaseLayout>
