---
import { getImage } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeroServicesNew from "../../components/sections/shared/PageHeroServicesNew.astro";
import ElektroServices from "../../components/sections/elektroinstalace/ElektroServices.astro";
import ElektroApproach from "../../components/sections/elektroinstalace/ElektroApproach.astro";
import ElektroWhyUs from "../../components/sections/elektroinstalace/ElektroWhyUs.astro";
import PortfolioShowcaseAlternating from "../../components/sections/shared/PortfolioShowcaseAlternating.astro";
import ContactSection from "../../components/sections/shared/ContactSection.astro";
import elektroImage from "../../assets/images/elektroinstalace.jpg";
import { SITE_URL } from "../../data/company";

const title = `Elektroinstalace <br /> pro váš domov i firmu`;
const description =
  "Zajistíme kompletní a bezpečné elektroinstalace pro váš rodinný dům, byt i firmu. Od prvotního návrhu až po konečnou revizi, vše s maximálním důrazem na kvalitu.";

const [img640, img1024, img1280] = await Promise.all([
  getImage({ src: elektroImage, width: 640, format: "avif", quality: 75 }),
  getImage({ src: elektroImage, width: 1024, format: "avif", quality: 75 }),
  getImage({ src: elektroImage, width: 1280, format: "avif", quality: 75 }),
]);
const preloadSrcset = `${img640.src} 640w, ${img1024.src} 1024w, ${img1280.src} 1280w`;

const siteUrl = (Astro.site ?? new URL(SITE_URL)).toString().replace(/\/$/, "");
const pageUrl = `${siteUrl}/sluzby/elektroinstalace`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: "Elektroinstalace",
    name: "Elektroinstalace",
    description,
    provider: { "@id": `${siteUrl}/#company` },
    areaServed: { "@type": "AdministrativeArea", name: "Klatovy a okolí" },
    url: pageUrl,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Domů", item: `${siteUrl}/` },
      {
        "@type": "ListItem",
        position: 2,
        name: "Elektroinstalace",
        item: pageUrl,
      },
    ],
  },
];
---

<BaseLayout
  pageTitle="Elektroinstalace v Klatovech"
  pageDescription={description}
  ogImage={elektroImage.src}
  ogImageAlt="Elektroinstalace v Klatovech a okolí"
  structuredData={structuredData}
>
  <link
    slot="head"
    rel="preload"
    as="image"
    imagesrcset={preloadSrcset}
    imagesizes="100vw"
    fetchpriority="high"
  />
  <PageHeroServicesNew
    slot="hero"
    id="hero"
    eyebrow="Elektro Klatovy a okolí"
    titleHtml={title}
    description={description}
    primaryCta={{ label: "Nezávazná poptávka", href: "/kontakt" }}
    secondaryCta={{ label: "Naše realizace", href: "/realizace" }}
    backgroundImage={elektroImage}
    backgroundImageAlt="Elektroinstalace — zapojování rozvaděče a elektrických okruhů"
  />
  <ElektroServices />
  <ElektroApproach />
  <ElektroWhyUs />
  <PortfolioShowcaseAlternating />
  <ContactSection />
</BaseLayout>
