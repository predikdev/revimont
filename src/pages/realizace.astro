---
import { getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeroServicesNew from "../components/sections/shared/PageHeroServicesNew.astro";
import ProjectsGrid from "../components/sections/realizace/ProjectsGrid.astro";
import ContactSection from "../components/sections/shared/ContactSection.astro";
import heroImage from "../assets/images/el_prace_3.jpeg";
import { createBreadcrumbSchema } from "../lib/seo";

const [img640, img1024, img1280] = await Promise.all([
  getImage({ src: heroImage, width: 640, format: "avif", quality: 75 }),
  getImage({ src: heroImage, width: 1024, format: "avif", quality: 75 }),
  getImage({ src: heroImage, width: 1280, format: "avif", quality: 75 }),
]);
const preloadSrcset = `${img640.src} 640w, ${img1024.src} 1024w, ${img1280.src} 1280w`;

const structuredData = createBreadcrumbSchema(Astro.site, [
  { name: "Domů", path: "/" },
  { name: "Realizace", path: "/realizace" },
]);
---

<BaseLayout
  pageTitle="Naše realizace v praxi"
  pageDescription="Ukázky realizací Revimont Klatovy — elektroinstalace, revize a montáže v Klatovech a okolí. Přesvědčte se o kvalitě naší práce."
  structuredData={structuredData}
>
  <link
    slot="head"
    rel="preload"
    as="image"
    imagesrcset={preloadSrcset}
    imagesizes="100vw"
    fetchpriority="high"
  />
  <PageHeroServicesNew
    slot="hero"
    eyebrow="Reference Revimont"
    titleLines={["Ukázky naší", "práce"]}
    description="Každý projekt realizujeme s maximální pečlivostí. Prohlédněte si naše dokončené zakázky v Klatovech a okolí."
    primaryCta={{ label: "Kontaktujte nás", href: "/kontakt" }}
    backgroundImage={heroImage}
    backgroundImageAlt="Realizované projekty — elektroinstalace a revize Revimont Klatovy"
  />
  <ProjectsGrid />
  <ContactSection />
</BaseLayout>
