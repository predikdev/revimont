---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeroServicesNew from "../components/sections/shared/PageHeroServicesNew.astro";
import PortfolioShowcaseAlternating from "../components/sections/shared/PortfolioShowcaseAlternating.astro";
import ContactSection from "../components/sections/shared/ContactSection.astro";
import heroImage from "../assets/images/el_prace_3.jpeg";
import { SITE_URL } from "../data/company";

const siteUrl = (Astro.site ?? new URL(SITE_URL)).toString().replace(/\/$/, "");

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Domů", item: `${siteUrl}/` },
    {
      "@type": "ListItem",
      position: 2,
      name: "Realizace",
      item: `${siteUrl}/realizace`,
    },
  ],
};
---

<BaseLayout
  pageTitle="Naše realizace v praxi"
  pageDescription="Ukázky realizací Revimont Klatovy — elektroinstalace, revize a montáže v Klatovech a okolí. Přesvědčte se o kvalitě naší práce."
  ogImage={heroImage.src}
  ogImageAlt="Realizované projekty Revimont Klatovy"
  structuredData={structuredData}
>
  <PageHeroServicesNew
    slot="hero"
    eyebrow="Reference Revimont"
    titleHtml={`Ukázky naší<br /> práce`}
    description="Každý projekt realizujeme s maximální pečlivostí. Prohlédněte si naše dokončené zakázky v Klatovech a okolí."
    backgroundImage={heroImage}
    backgroundImageAlt="Realizované projekty — elektroinstalace a revize Revimont Klatovy"
  />
  <PortfolioShowcaseAlternating
    eyebrow="Reference"
    title="Naše realizované projekty"
    description="Podívejte se na ukázky naší práce. Každý projekt řešíme s důrazem na kvalitu, bezpečnost a spokojenost klienta."
  />
  <ContactSection />
</BaseLayout>
