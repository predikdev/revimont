---
import { House, Grid2x2, Zap, LayoutList } from "@lucide/astro";
import ServicesGridSection from "../shared/ServicesGridSection.astro";

const services = [
  {
    number: "01",
    icon: House,
    title: "Výchozí revize",
    description:
      "Revize nových nebo rekonstruovaných instalací před uvedením do provozu.",
    bullets: [
      "Nové instalace a rekonstrukce",
      "Kontrola prvků a zapojení",
      "Ověření bezpečnostních parametrů",
      "Doklad pro kolaudaci",
    ],
  },
  {
    number: "02",
    icon: Grid2x2,
    title: "Pravidelné revize",
    description:
      "Periodické kontroly stávajících zařízení pro bezpečný a bezproblémový provoz.",
    bullets: [
      "Včasné odhalení závad",
      "Kontrola rozvaděčů a okruhů",
      "Posouzení bezpečnosti provozu",
      "Doporučení nutných oprav",
    ],
  },
  {
    number: "03",
    icon: Zap,
    title: "Revize hromosvodů",
    description:
      "Revize hromosvodových soustav včetně návazných částí ochrany před bleskem.",
    bullets: [
      "Kontrola jímací soustavy",
      "Měření hodnot uzemnění",
      "Nutné po úpravách střechy",
      "Doklad pro pojišťovnu",
    ],
  },
  {
    number: "04",
    icon: LayoutList,
    title: "Revizní zprávy a dokumentace",
    description:
      "Kompletní zpracování a předání oficiální dokumentace o stavu elektroinstalace.",
    bullets: [
      "Oficiální platný dokument",
      "Detailní přehled měření",
      "Konkrétní návrhy nápravy",
      "Rychlé dodání v PDF",
    ],
  },
];
---

<ServicesGridSection
  title="Revize"
  description="Komplexní služby v oblasti elektrorevizí pro domácnosti i firmy. Od kontroly rozvaděčů až po měření hromosvodů a zpracování oficiální dokumentace – přesně podle aktuálních norem."
  services={services}
/>
