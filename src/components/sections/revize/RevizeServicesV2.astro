---
import SectionWrapper from "../../ui/SectionWrapper.astro";
import ServiceCard from "../../ui/ServiceCard.astro";
import { House, Grid2x2, Zap, LayoutList } from "@lucide/astro";

const services = [
  {
    number: "01",
    icon: House,
    title: "Výchozí revize",
    description:
      "Revize nových nebo rekonstruovaných instalací před uvedením do provozu.",
    bullets: [
      "Nové instalace a rekonstrukce",
      "Kontrola prvků a zapojení",
      "Ověření bezpečnostních parametrů",
      "Doklad pro kolaudaci",
    ],
  },
  {
    number: "02",
    icon: Grid2x2,
    title: "Pravidelné revize",
    description:
      "Periodické kontroly stávajících zařízení pro bezpečný a bezproblémový provoz.",
    bullets: [
      "Včasné odhalení závad",
      "Kontrola rozvaděčů a okruhů",
      "Posouzení bezpečnosti provozu",
      "Doporučení nutných oprav",
    ],
  },
  {
    number: "03",
    icon: Zap,
    title: "Revize hromosvodů",
    description:
      "Revize hromosvodových soustav včetně návazných částí ochrany před bleskem.",
    bullets: [
      "Kontrola jímací soustavy",
      "Měření hodnot uzemnění",
      "Nutné po úpravách střechy",
      "Doklad pro pojišťovnu",
    ],
  },
  {
    number: "04",
    icon: LayoutList,
    title: "Revizní zprávy a dokumentace",
    description:
      "Kompletní zpracování a předání oficiální dokumentace o stavu elektroinstalace.",
    bullets: [
      "Oficiální platný dokument",
      "Detailní přehled měření",
      "Konkrétní návrhy nápravy",
      "Rychlé dodání v PDF",
    ],
  },
];
---

<SectionWrapper background="light" withGrid class="bg-background">
  {/* Header */}
  <div class="mb-12">
    <div class="mb-4 flex items-center gap-3">
      <span class="bg-accent-primary h-px w-8" aria-hidden="true"></span>
      <p
        class="text-accent-primary text-sm font-semibold tracking-widest uppercase"
      >
        Naše služby
      </p>
    </div>
    <h2
      class="font-sora mb-5 text-4xl leading-tight font-bold text-neutral-800 sm:text-5xl lg:text-6xl"
    >
      Revize
    </h2>
    <p class="max-w-xl text-base leading-relaxed text-neutral-800/70">
      Komplexní služby v oblasti elektrorevizí pro domácnosti i firmy. Od
      kontroly rozvaděčů až po měření hromosvodů a zpracování oficiální
      dokumentace – přesně podle aktuálních norem.
    </p>
  </div>

  {/* 2×2 grid */}
  <div class="grid gap-4 sm:grid-cols-2">
    {
      services.map((service) => {
        const ServiceIcon = service.icon;
        return (
          <ServiceCard
            number={service.number}
            title={service.title}
            description={service.description}
            bullets={service.bullets}
          >
            <ServiceIcon
              slot="icon"
              class="text-accent-primary h-5 w-5 transition-transform duration-300 group-hover:scale-110"
            />
          </ServiceCard>
        );
      })
    }
  </div>
</SectionWrapper>
