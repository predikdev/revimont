---
import SectionWrapper from "../../ui/SectionWrapper.astro";
import ServiceCard from "../../ui/ServiceCard.astro";
import { House, Grid2x2, Zap, LayoutList } from "@lucide/astro";

const services = [
  {
    number: "01",
    title: "Rodinné domy a byty",
    description:
      "Kompletní elektroinstalace pro novostavby i rekonstrukce. Navrhujeme a realizujeme řešení přizpůsobená modernímu bydlení.",
    icon: House,
    bullets: [
      "Novostavby na klíč",
      "Rekonstrukce jádra",
      "Smart Home",
      "Hromosvody",
    ],
  },
  {
    number: "02",
    title: "Bytové domy a SVJ",
    description:
      "Elektro revize a instalace v panelových a bytových domech. Výměna stoupaček HDV, modernizace osvětlení a další.",
    icon: Grid2x2,
    bullets: [
      "Výměna HDV",
      "Renovace společných prostor",
      "Zámecké kabeláže",
      "Společné prostory",
    ],
  },
  {
    number: "03",
    title: "Elektrické přípojky",
    description:
      "Připojení pozemků a objektů k distribuční síti EGD, E.ON. Provedeme výkopy a osadíme pilíř.",
    icon: Zap,
    bullets: [
      "Přípojkové skříně",
      "Elektroměrový proud",
      "Zemní práce",
      "Přísliby a odložky",
    ],
  },
  {
    number: "04",
    title: "Rozvaděče",
    description:
      "Distribuce a zapouzdřená rozvaděče na míru. Od malých bytových skříní po velké technologické rozvaděče.",
    icon: LayoutList,
    bullets: [
      "Bytové rozvaděče",
      "Elektrické stojky",
      "Rozvaděče strojní měření",
      "Průmysl",
    ],
  },
];
---

<SectionWrapper background="light" withGrid class="bg-background">
  {/* Header */}
  <div class="mb-12">
    <div class="mb-4 flex items-center gap-3">
      <span class="bg-accent-primary h-px w-8" aria-hidden="true"></span>
      <p
        class="text-accent-primary text-sm font-semibold tracking-widest uppercase"
      >
        Naše služby
      </p>
    </div>
    <h2
      class="font-sora mb-5 text-4xl leading-tight font-bold text-neutral-800 sm:text-5xl lg:text-6xl"
    >
      Elektroinstalace
    </h2>
    <p class="max-w-xl text-base leading-relaxed text-neutral-800/70">
      Elektroinstalace, revize i montáže technologií zajistíme pro domácnosti,
      bytové domy i firmy. Nabízíme spolehlivá řešení od návrhu až po realizaci
      a záruční servis.
    </p>
  </div>

  {/* 2×2 grid */}
  <div class="grid gap-4 sm:grid-cols-2">
    {
      services.map((service) => {
        const ServiceIcon = service.icon;
        return (
          <ServiceCard
            number={service.number}
            title={service.title}
            description={service.description}
            bullets={service.bullets}
          >
            <ServiceIcon
              slot="icon"
              class="text-accent-primary h-5 w-5 transition-transform duration-300 group-hover:scale-110"
            />
          </ServiceCard>
        );
      })
    }
  </div>
</SectionWrapper>
