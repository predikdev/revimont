---
import { House, Grid2x2, Zap, LayoutList } from "@lucide/astro";
import ServicesGridSection from "../shared/ServicesGridSection.astro";

const services = [
  {
    number: "01",
    title: "Rodinné domy a byty",
    description:
      "Kompletní elektroinstalace pro novostavby i rekonstrukce. Navrhujeme a realizujeme řešení přizpůsobená modernímu bydlení.",
    icon: House,
    bullets: [
      "Novostavby na klíč",
      "Rekonstrukce jádra",
      "Smart Home",
      "Hromosvody",
    ],
  },
  {
    number: "02",
    title: "Bytové domy a SVJ",
    description:
      "Elektro revize a instalace v panelových a bytových domech. Výměna stoupaček HDV, modernizace osvětlení a další.",
    icon: Grid2x2,
    bullets: [
      "Výměna HDV",
      "Renovace společných prostor",
      "Zámkové systémy",
      "Společné prostory",
    ],
  },
  {
    number: "03",
    title: "Elektrické přípojky",
    description:
      "Připojení pozemků a objektů k distribuční síti EGD, E.ON. Provedeme výkopy a osadíme pilíř.",
    icon: Zap,
    bullets: [
      "Přípojkové skříně",
      "Elektroměrový proud",
      "Zemní práce",
      "Přísliby a odložky",
    ],
  },
  {
    number: "04",
    title: "Rozvaděče",
    description:
      "Distribuce a zapouzdřená rozvaděče na míru. Od malých bytových skříní po velké technologické rozvaděče.",
    icon: LayoutList,
    bullets: [
      "Bytové rozvaděče",
      "Elektrické stojky",
      "Rozvaděče strojní měření",
      "Průmysl",
    ],
  },
];
---

<ServicesGridSection
  title="Elektroinstalace"
  description="Elektroinstalace, revize i montáže technologií zajistíme pro domácnosti, bytové domy i firmy. Nabízíme spolehlivá řešení od návrhu až po realizaci a záruční servis."
  services={services}
/>
