---
import {
  BadgeCheck,
  FileText,
  Receipt,
  CalendarCheck,
  Users,
  ThumbsUp,
} from "@lucide/astro";
import WhyUsSection from "../shared/WhyUsSection.astro";

const features = [
  {
    title: "Certifikovaní elektrikáři",
    description:
      "Všechny práce provádějí odborníci s platnou kvalifikací dle vyhlášky č. 50/1978 Sb. a vlastním revizním technikem pro maximální bezpečnost vaší instalace.",
    icon: BadgeCheck,
  },
  {
    title: "Revizní zpráva v ceně",
    description:
      "Ke každé dokončené zakázce od nás obdržíte kompletní revizní zprávu. Vše je zahrnuto v ceně, bez skrytých příplatků a s garancí splnění všech norem.",
    icon: FileText,
  },
  {
    title: "Transparentní ceny",
    description:
      "Cenovou nabídku od nás dostanete vždy položkově rozepsanou do nejmenších detailů. Přesně víte, za co platíte a na konci vás nečeká žádné nemilé překvapení.",
    icon: Receipt,
  },
  {
    title: "Dodržujeme termíny",
    description:
      "Víme, jak je váš čas drahý, proto dohodnutý termín zahájení i dokončení prací bereme jako závazek. O průběhu vás informujeme včas a zcela proaktivně.",
    icon: CalendarCheck,
  },
  {
    title: "Vlastní stálá četa",
    description:
      "Na projektech pracují pouze naši stálí zaměstnanci, nikoliv nárazoví brigádníci. Tímto přístupem zaručujeme konstantně vysokou kvalitu na každé zakázce.",
    icon: Users,
  },
  {
    title: "Záruční servis bez starostí",
    description:
      "Na veškeré provedené práce poskytujeme plnou záruku. V případě potřeby záručního i pozáručního servisu jsme tu pro vás vždy na prvním místě s rychlým řešením.",
    icon: ThumbsUp,
  },
];

const stats = [
  { value: "15+", label: "Let zkušeností" },
  { value: "300+", label: "Dokončených zakázek" },
  { value: "100%", label: "Bezpečnost" },
  { value: "Klatovy", label: "A široké okolí" },
];
---

<WhyUsSection
  description="Výběr elektrikáře není o nejnižší ceně. Jde o spolehlivost, bezpečnost a klid v hlavě."
  features={features}
  stats={stats}
/>
