---
import { MessageCircle, Wrench, Handshake } from "@lucide/astro";
import ApproachSection from "../shared/ApproachSection.astro";

const steps = [
  {
    number: "01",
    icon: MessageCircle,
    title: "Konzultace a návrh",
    description:
      "Osobně probereme vaše požadavky, prohlédneme prostory a připravíme transparentní cenovou nabídku s termínem realizace.",
    bullets: [
      "Osobní prohlídka místa",
      "Návrh variant řešení",
      "Jasná cenová kalkulace",
    ],
  },
  {
    number: "02",
    icon: Wrench,
    title: "Precizní realizace",
    description:
      "Instalaci provádíme čistě a přesně, s použitím ověřených komponentů od renomovaných značek. Průběžně kontrolujeme kvalitu.",
    bullets: [
      "Ověřené materiály a komponenty",
      "Průběžná kontrola kvality",
      "Minimální zásah do interiéru",
    ],
  },
  {
    number: "03",
    icon: Handshake,
    title: "Předání a servis",
    description:
      "Dílo předáme plně funkční včetně revizní zprávy. Zaškolíme obsluhu a poskytujeme záruční i pozáruční servis.",
    bullets: [
      "Revizní zpráva k předání",
      "Zaškolení obsluhy",
      "Záruční a pozáruční podpora",
    ],
  },
];
---

<ApproachSection
  title="Jak probíhá elektroinstalace"
  description="Od prvního kontaktu po předání. Tři kroky, žádné překvapení."
  steps={steps}
/>
