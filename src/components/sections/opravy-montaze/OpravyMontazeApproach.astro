---
import { Phone, Wrench, Handshake } from "@lucide/astro";
import ApproachSection from "../shared/ApproachSection.astro";

const steps = [
  {
    number: "01",
    icon: Phone,
    title: "Nahlášení a termín",
    description:
      "Zavolejte nebo napište — stručně popište závadu. Domluvíme termín výjezdu, přijedeme vybaveni a připraveni.",
    bullets: [
      "Rychlá odezva do 2 hodin",
      "Konzultace po telefonu zdarma",
      "Domluvení termínu výjezdu",
    ],
  },
  {
    number: "02",
    icon: Wrench,
    title: "Diagnostika a oprava",
    description:
      "Na místě zjistíme příčinu, sdělíme jasnou cenu a opravíme závadu nebo provedeme montáž. Čistě a bez zbytečných průtahů.",
    bullets: [
      "Transparentní cenová nabídka",
      "Odborné provedení opravy",
      "Kvalitní náhradní díly",
    ],
  },
  {
    number: "03",
    icon: Handshake,
    title: "Předání a záruka",
    description:
      "Celý systém otestujeme, předáme vám doklad o provedení práce a poskytneme záruční servis.",
    bullets: [
      "Funkční test po dokončení",
      "Doklad o provedené práci",
      "Záruční podpora",
    ],
  },
];
---

<ApproachSection
  title="Jak probíhá oprava nebo montáž"
  description="Od nahlášení po předání hotové práce. Bez komplikací, bez čekání."
  steps={steps}
/>
