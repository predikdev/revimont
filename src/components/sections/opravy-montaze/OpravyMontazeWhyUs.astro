---
import {
  BadgeCheck,
  Receipt,
  CalendarCheck,
  Wrench,
  ShieldCheck,
  Users,
} from "@lucide/astro";
import WhyUsSection from "../shared/WhyUsSection.astro";

const features = [
  {
    title: "Certifikovaní elektrikáři",
    description:
      "Montáže a opravy provádějí odborníci s platnou kvalifikací dle vyhlášky č. 50/1978 Sb. Práce jsou prováděny bezpečně, odborně a v souladu s veškerými normami.",
    icon: BadgeCheck,
  },
  {
    title: "Transparentní ceny",
    description:
      "Cenovou nabídku od nás dostanete vždy položeně rozepsanou tak, abyste přesně věděli, co platíte. Transparentnost je pro nás klíčová pro vaši maximální spokojenost.",
    icon: Receipt,
  },
  {
    title: "Dodržujeme termíny",
    description:
      "Víme, jak je váš čas drahý, proto dohodnutý termín zahájení i dokončení prací bereme jako závazek. O průběhu vás informujeme včas a zcela proaktivně.",
    icon: CalendarCheck,
  },
  {
    title: "Opravíme, ne jen vyměníme",
    description:
      "Nejdříve diagnostikujeme závadu a hledáme nejefektivnější řešení opravy. Nový systém doporučíme jen tehdy, kdy to dává smysl a šetří vaše budoucí náklady.",
    icon: Wrench,
  },
  {
    title: "Záruka na provedené práce",
    description:
      "Na všechny provedené opravy a montáže poskytujeme plnou záruku. V případě jakýchkoli potíží po dokončení jsme vám k dispozici pro rychlé a efektivní řešení.",
    icon: ShieldCheck,
  },
  {
    title: "Vlastní stálá četa",
    description:
      "Na projektech pracují pouze naši stálí zaměstnanci, nikoliv nárazoví brigádníci. Tímto přístupem zaručujeme konstantně vysokou kvalitu na každé zakázce.",
    icon: Users,
  },
];

const stats = [
  { value: "15+", label: "Let zkušeností" },
  { value: "300+", label: "Dokončených zakázek" },
  { value: "100%", label: "Funkčnost" },
  { value: "Klatovy", label: "A široké okolí" },
];
---

<WhyUsSection
  description="Výběr servisního technika není o nejnižší ceně. Jde o odbornost, férovost a jistotu, že práce bude hotová správně."
  features={features}
  stats={stats}
/>
