---
import { Image } from "astro:assets";
import SectionWrapper from "../../ui/SectionWrapper.astro";
import SectionHeader from "../../ui/SectionHeader.astro";
import Button from "../../ui/Button.astro";

import { ChevronRight } from "@lucide/astro";
import { projects } from "../../../data/projects";

interface Props {
  title?: string;
  eyebrow?: string;
  description?: string;
  projectSlugs?: string[];
}

const {
  title = "Ukázky našich elektroinstalací",
  eyebrow = "Portfolio",
  description,
  projectSlugs,
} = Astro.props;

const selectedProjects = projectSlugs
  ? projects.filter((project) => projectSlugs.includes(project.slug))
  : projects;

const featuredProjects = selectedProjects.map((project) => ({
  title: project.title,
  description: project.description,
  meta: project.location,
  image: project.heroImage,
  imageAlt: project.heroImageAlt,
  href: `/realizace/${project.slug}`,
}));
---

<SectionWrapper background="light" withGrid>
  <div class="mb-12 lg:mb-14">
    <SectionHeader
      eyebrow={eyebrow}
      title={title}
      description={description}
      class="mb-0"
      background="light"
    />
  </div>

  <div class="flex w-full flex-col gap-20 lg:gap-32">
    {
      featuredProjects.map((project, index) => (
        <article>
          <div class="grid items-center gap-8 md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] md:gap-10">
            <a
              href={project.href}
              class:list={[
                "relative block",
                index === 1 ? "md:order-2" : "md:order-1",
              ]}
            >
              <div class="relative h-64 overflow-hidden rounded-xl md:h-72 lg:h-80">
                <Image
                  src={project.image}
                  alt={project.imageAlt}
                  widths={[400, 800, 1200]}
                  sizes="(min-width: 768px) 50vw, 100vw"
                  class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
                  loading="lazy"
                  quality={80}
                />
                <div
                  aria-hidden="true"
                  class="pointer-events-none absolute inset-0 bg-linear-to-t from-neutral-900/35 via-transparent to-transparent"
                />
              </div>
            </a>

            <div
              class:list={[
                "max-w-xl",
                index === 1 ? "md:order-1" : "md:order-2",
              ]}
            >
              <h3 class="font-sora text-4xl leading-tight font-bold text-neutral-800">
                {project.title}
              </h3>
              <p class="text-accent-primary mt-3 text-sm font-semibold">
                {project.meta}
              </p>
              <p class="mt-5 text-base leading-relaxed text-neutral-800/70">
                {project.description}
              </p>

              <div class="mt-6">
                <Button
                  href={project.href}
                  variant="secondaryLight"
                  size="md"
                  class="w-fit px-5 py-2.5"
                >
                  Detail projektu
                  <ChevronRight aria-hidden="true" class="h-4 w-4" />
                </Button>
              </div>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</SectionWrapper>
