---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import SectionWrapper from "../../ui/SectionWrapper.astro";
import ServiceCard from "../../ui/ServiceCard.astro";

interface ServiceItem {
  number: string;
  title: string;
  description: string;
  icon: AstroComponentFactory;
  bullets: string[];
}

interface Props {
  title: string;
  description: string;
  services: ServiceItem[];
  columns?: "2" | "3";
}

const { title, description, services, columns = "2" } = Astro.props;
---

<SectionWrapper background="light" withGrid class="bg-background">
  <div class="mb-12">
    <div class="mb-4 flex items-center gap-3">
      <span class="bg-accent-primary h-px w-8" aria-hidden="true"></span>
      <p
        class="text-accent-primary text-sm font-semibold tracking-widest uppercase"
      >
        Naše služby
      </p>
    </div>
    <h2
      class="font-sora mb-5 text-4xl leading-tight font-bold text-neutral-800 sm:text-5xl lg:text-6xl"
    >
      {title}
    </h2>
    <p class="max-w-xl text-base leading-relaxed text-neutral-800/70">
      {description}
    </p>
  </div>

  <div
    class:list={[
      "grid gap-4 sm:grid-cols-2",
      columns === "3" && "lg:grid-cols-3",
    ]}
  >
    {
      services.map((service) => {
        const ServiceIcon = service.icon;
        return (
          <ServiceCard
            number={service.number}
            title={service.title}
            description={service.description}
            bullets={service.bullets}
          >
            <ServiceIcon
              slot="icon"
              class="text-accent-primary h-5 w-5 transition-transform duration-300 group-hover:scale-110"
            />
          </ServiceCard>
        );
      })
    }
  </div>
</SectionWrapper>
