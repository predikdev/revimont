---
import { Image } from "astro:assets";
import SectionWrapper from "../../ui/SectionWrapper.astro";
import SectionHeader from "../../ui/SectionHeader.astro";
import Button from "../../ui/Button.astro";
import { MapPin, ChevronRight } from "@lucide/astro";
import { projects } from "../../../data/projects";
---

<SectionWrapper background="light" withGrid>
  <SectionHeader
    eyebrow="Naše reference"
    title="Realizované projekty"
    description="Podívejte se na ukázky naší práce. Každý projekt řešíme s důrazem na kvalitu, bezpečnost a spokojenost klienta."
    background="light"
    align="center"
  />

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      projects.map((project) => (
        <article class="group flex flex-col overflow-hidden rounded-xl border border-neutral-200 bg-white shadow-sm transition-shadow duration-200 hover:shadow-md">
          <a
            href={`/realizace/${project.slug}`}
            class="relative block h-52 overflow-hidden"
            aria-label={`Zobrazit detail projektu: ${project.title}`}
            tabindex="-1"
          >
            <Image
              src={project.heroImage}
              alt={project.heroImageAlt}
              widths={[400, 700]}
              sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              quality={80}
            />
            <div
              aria-hidden="true"
              class="absolute inset-0 bg-linear-to-t from-neutral-900/40 via-transparent to-transparent"
            />
            <span class="absolute top-3 left-3 rounded-full bg-neutral-900/70 px-3 py-1 text-xs font-semibold text-neutral-100 backdrop-blur-sm">
              {project.category}
            </span>
          </a>

          <div class="flex flex-1 flex-col p-6">
            <div class="mb-3 flex items-center gap-1.5 text-xs font-medium text-neutral-500">
              <MapPin class="h-3.5 w-3.5 shrink-0" aria-hidden="true" />
              {project.location}
            </div>

            <h2 class="font-sora mb-2 text-lg leading-snug font-bold text-neutral-800">
              <a
                href={`/realizace/${project.slug}`}
                class="hover:text-accent-primary transition-colors"
              >
                {project.title}
              </a>
            </h2>

            <p class="mb-5 line-clamp-3 flex-1 text-sm leading-relaxed text-neutral-500">
              {project.description}
            </p>

            <Button
              href={`/realizace/${project.slug}`}
              variant="secondaryLight"
              size="sm"
              class="mt-auto w-fit"
            >
              Detail projektu
              <ChevronRight aria-hidden="true" class="h-4 w-4" />
            </Button>
          </div>
        </article>
      ))
    }
  </div>
</SectionWrapper>
