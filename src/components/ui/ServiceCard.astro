---
import { CircleCheck } from "@lucide/astro";

interface Props {
  number: string;
  title: string;
  description: string;
  bullets: string[];
}

const { number, title, description, bullets } = Astro.props;
---

<div
  class="group relative flex flex-col overflow-hidden rounded-xl border border-neutral-200 bg-white p-8 shadow-sm transition-shadow duration-200 hover:shadow-md"
>
  {/* Hover accent line – slides in from top */}
  <span
    aria-hidden="true"
    class="bg-accent-primary absolute top-0 left-1/2 h-[3px] w-4/5 -translate-x-1/2 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
  ></span>

  {/* Icon + Number */}
  <div class="mb-6 flex items-start justify-between">
    <div
      class="bg-accent-primary/10 group-hover:bg-accent-primary/[0.18] flex h-11 w-11 items-center justify-center rounded-xl transition-colors duration-300"
    >
      <slot name="icon" />
    </div>
    <span
      class="font-sora text-accent-primary/20 group-hover:text-accent-primary/40 text-6xl leading-none font-bold transition-colors duration-300"
    >
      {number}
    </span>
  </div>

  {/* Title & Description */}
  <h3 class="mb-3 text-xl font-bold text-neutral-800">{title}</h3>
  <p class="mb-auto text-sm leading-relaxed text-neutral-500">{description}</p>

  {/* Divider */}
  <hr class="my-6 border-neutral-200" />

  {/* Bullets – 2 columns */}
  <ul class="grid grid-cols-2 gap-x-6 gap-y-3">
    {
      bullets.map((bullet) => (
        <li class="flex items-center gap-2">
          <CircleCheck class="text-accent-primary h-4 w-4 shrink-0" />
          <span class="text-sm text-neutral-700">{bullet}</span>
        </li>
      ))
    }
  </ul>
</div>
