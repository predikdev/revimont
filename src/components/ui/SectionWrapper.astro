---
interface Props {
  id?: string;
  background?: "light" | "dark";
  withGrid?: boolean;
  class?: string;
}

const {
  id,
  background = "light",
  withGrid = false,
  class: className = "",
} = Astro.props;
---

<section
  id={id}
  data-animate-section
  class:list={[
    "relative overflow-hidden py-20 lg:py-24",
    background === "dark" ? "bg-neutral-800" : "bg-background",
    className,
  ]}
>
  {
    withGrid && (
      <div class="bg-grid-pattern absolute inset-0" aria-hidden="true" />
    )
  }

  <div class="relative z-10 container">
    <slot />
  </div>
</section>
